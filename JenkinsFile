pipeline {
    agent any

    tools {
        maven 'Maven'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/Dhruva426000/ansiblej.git'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Deploy') {
            steps {
                sh 'ansible-playbook playbook.yml -i hosts.ini'
            }
        }
    }

    post {
        success {
            echo 'Deployment Successful!'
            echo 'Application URL: http://localhost:9090/ansiblej'
        }

        failure {
            echo 'Deployment Failed!'
        }
    }
}
